  {
    "id": "rain_format",
    "type": "function",
    "z": "tab_task2_rain",
    "name": "Rain Dashboard + Alert Router",
    "func": "// Task 2 - 24127192\n// Hien thi rain sensor tren web va tao alert neu co mua.\nconst p = msg.payload || {};\nmsg.payload = {\n    type: 'rain',\n    severity: p.isRaining ? 'warning' : 'info',\n    message: p.isRaining ? `Phat hien mua (${p.rainPercent}%). Nen thu sao phoi.` : 'Khong mua.',\n    rainPercent: p.rainPercent,\n    isRaining: Boolean(p.isRaining),\n    deviceId: p.deviceId,\n    timestamp: p.timestamp\n};\nif (p.isRaining) {\n    return [msg, RED.util.cloneMessage(msg)];\n}\nreturn [msg, null];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 650,
    "y": 120,
    "wires": [
      [
        "rain_debug"
      ],
      [
        "alert_link_out"
      ]
    ]
