    "id": "alert_build_fcm",
    "type": "function",
    "z": "tab_alerts",
    "name": "Task 6 - Build FCM Payload",
    "func": "// Task 6 - 24127192\n// Tao payload cho node FCM. Token/topic se cau hinh trong node FCM thuc te.\nconst alert = msg.payload || {};\nmsg.payload = {\n    notification: {\n        title: 'SmartDry canh bao',\n        body: alert.message || 'Co canh bao moi tu SmartDry'\n    },\n    data: {\n        type: String(alert.type || 'alert'),\n        severity: String(alert.severity || 'warning'),\n        deviceId: String(alert.deviceId || 'smartdry-01')\n    }\n};\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
