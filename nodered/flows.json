  {
    "id": "auth_hash",
    "type": "function",
    "z": "tab_auth",
    "name": "Task 9 - Hash/Login Skeleton",
    "func": "// Task 9 - 24127192\n// Skeleton dang nhap. Trong ban hoan thien, doc accounts tu Firestore va so sanh passwordHash.\n// Node-RED Function mac dinh khong nen luu password plain text.\nconst user = msg.payload || {};\nif (!user.username || !user.password) {\n    msg.payload = { authenticated: false, reason: 'missing_credentials' };\n    return [null, msg];\n}\nmsg.accountQuery = {\n    collection: 'accounts',\n    field: 'username',\n    operator: '==',\n    value: user.username\n};\nmsg.passwordToVerify = user.password;\nmsg.payload = { username: user.username, next: 'query_firestore_accounts' };\nreturn [msg, null];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 440,
    "y": 100,
    "wires": [
