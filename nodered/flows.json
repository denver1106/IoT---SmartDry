    "id": "alert_build_email",
    "type": "function",
    "z": "tab_alerts",
    "name": "Task 7 - Build Email",
    "func": "// Task 7 - 24127192\n// Tao email canh bao. Node email se dung msg.to, msg.topic, msg.payload.\nconst alert = msg.payload || {};\nmsg.to = 'receiver@example.com';\nmsg.topic = `[SmartDry] ${alert.severity || 'warning'} - ${alert.type || 'alert'}`;\nmsg.payload = `${alert.message || 'Co canh bao moi'}\\n\\nDevice: ${alert.deviceId || 'smartdry-01'}\\nTime: ${new Date().toLocaleString('vi-VN')}`;\nreturn msg;",
    "outputs": 1,
